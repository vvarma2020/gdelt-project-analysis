# Local project configuration. The CLI auto-loads this file from the project root.

GDELT_PROJECT_ROOT=.
GDELT_DATA_ROOT=data
GDELT_STATE_ROOT=state
GDELT_DUCKDB_PATH=data/gdelt.duckdb
GDELT_CHECKPOINT_PATH=state/checkpoint.json
GDELT_MASTERFILE_URL=http://data.gdeltproject.org/gdeltv2/masterfilelist.txt
GDELT_RAW_RETENTION_DAYS=7
GDELT_REQUEST_TIMEOUT_SECONDS=60
GDELT_CA_BUNDLE_PATH=.venv/lib/python3.12/site-packages/certifi/cacert.pem

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
